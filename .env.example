# ============================================================
# VARIABLES DE ENTORNO - PORTAFOLIO
# ============================================================
# Copia este archivo a .env.local y completa con tus valores reales
# NUNCA subas el archivo .env.local a GitHub

# ============================================================
# EMAIL (RESEND)
# ============================================================
# Obtén tu API key en: https://resend.com/api-keys
# Necesario para el formulario de contacto
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email donde recibirás los mensajes del formulario de contacto
CONTACT_EMAIL=tumail@ejemplo.com

# ============================================================
# METADATA Y SEO
# ============================================================
# URL base de tu sitio (usa tu dominio en producción)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ============================================================
# ANALYTICS (OPCIONAL)
# ============================================================
# Vercel Analytics se configura automáticamente en Vercel
# No requiere variables adicionales

# ============================================================
# NOTAS
# ============================================================
# - Variables con NEXT_PUBLIC_ son accesibles desde el cliente
# - Variables sin NEXT_PUBLIC_ solo están disponibles en el servidor
# - Reinicia el servidor después de cambiar variables de entorno
